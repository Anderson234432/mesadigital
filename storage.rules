rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /platos/{allPaths=**} {
      // Imágenes del menú: lectura pública (clientes las ven en el menú)
      allow read: if true;
      // Solo staff autenticado con email/password puede subir o eliminar
      // Los clientes anónimos tienen sign_in_provider == 'anonymous'
      allow write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
  }
}
