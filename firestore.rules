rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function esMaestro() {
      return request.auth != null
        && request.auth.uid == 'xB7aybhKvYhIkuq7TERTuMfUkaH2';
    }

    function getRestaurante(restauranteId) {
      return get(/databases/$(database)/documents/restaurantes/$(restauranteId)).data;
    }

    function restauranteExiste(restauranteId) {
      return exists(/databases/$(database)/documents/restaurantes/$(restauranteId));
    }

    // Admin: maestro O usuario en adminUids del restaurante
    function esAdmin(restauranteId) {
      return esMaestro() || (
        request.auth != null &&
        restauranteExiste(restauranteId) &&
        request.auth.uid in getRestaurante(restauranteId).get('adminUids', [])
      );
    }

    // Personal del restaurante: admin O usuario en cocinaUids
    function esPersonal(restauranteId) {
      return esMaestro() || (
        request.auth != null &&
        restauranteExiste(restauranteId) && (
          request.auth.uid in getRestaurante(restauranteId).get('adminUids', []) ||
          request.auth.uid in getRestaurante(restauranteId).get('cocinaUids', [])
        )
      );
    }

    // Si el restaurante tiene mesaTokens configurado, el token enviado debe
    // coincidir con el de esa mesa. Restaurantes sin mesaTokens no lo exigen
    // (compatibilidad hacia atrás).
    function tokenDeMesaValido(restauranteId, mesa, tokenEnviado) {
      let tokens = getRestaurante(restauranteId).get('mesaTokens', null);
      return tokens == null || tokens[mesa] == tokenEnviado;
    }

    // ── Restaurantes ───────────────────────────────────────────────────────────

    match /restaurantes/{restauranteId} {
      // Lectura pública: clientes necesitan nombre, tiempos y stats
      allow read: if true;

      // Solo el maestro puede crear o eliminar restaurantes
      allow create, delete: if esMaestro();

      // Maestro y admins pueden actualizar cualquier campo (tiempos, roles, mesaTokens...).
      // Cocina solo puede tocar stats (necesita actualizar stats.mesasPendientes al archivar).
      allow update: if
        esAdmin(restauranteId) ||
        (
          esPersonal(restauranteId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
        );

      // ── Platos ──────────────────────────────────────────────────────────────

      match /platos/{platoId} {
        // Lectura pública: clientes navegan el menú
        allow read: if true;
        // Solo admins gestionan el menú
        allow write: if esAdmin(restauranteId);
      }

      // ── Pedidos ─────────────────────────────────────────────────────────────

      match /pedidos/{pedidoId} {
        // Personal autenticado lee todos los pedidos.
        // Clientes anónimos solo leen sus propios pedidos (aislamiento por mesa).
        allow read: if
          request.auth != null && (
            esPersonal(restauranteId) ||
            resource.data.get('clienteUid', '') == request.auth.uid
          );

        // Clientes (auth anónima requerida) pueden crear pedidos.
        // La Cloud Function es el path normal (usa Admin SDK, omite estas reglas).
        // Este es el fallback cuando Cloud Functions no está disponible: aquí es
        // donde se rechazan pedidos con total/items fuera de rango, ya que este
        // path no coteja precios contra platos/ (ver nota en pedidosRepository.js).
        allow create: if
          request.auth != null &&
          request.resource.data.keys().hasAll(['mesa', 'items', 'total', 'estado', 'creadoEn']) &&
          request.resource.data.estado == 'pendiente' &&
          request.resource.data.mesa is string &&
          request.resource.data.mesa.size() > 0 &&
          request.resource.data.mesa.size() <= 20 &&
          restauranteExiste(restauranteId) &&
          tokenDeMesaValido(restauranteId, request.resource.data.mesa, request.resource.data.get('mesaToken', '')) &&
          request.resource.data.total is number &&
          request.resource.data.total >= 0 &&
          request.resource.data.total <= 50000 &&
          request.resource.data.items is list &&
          request.resource.data.items.size() <= 30 &&
          (
            // "Llamar al mesero" es un pedido sin platos: items vacío y total 0.
            request.resource.data.get('tipo', '') == 'llamada'
              ? (request.resource.data.items.size() == 0 && request.resource.data.total == 0)
              : (request.resource.data.items.size() > 0 && request.resource.data.total >= 1)
          ) &&
          request.resource.data.get('nota', '') is string &&
          request.resource.data.get('nota', '').size() <= 500;

        // Solo personal (cocina y admin) puede cambiar estado o archivar pedidos
        allow update, delete: if
          request.auth != null &&
          esPersonal(restauranteId);
      }

      // ── Rate limits (solo Cloud Function via Admin SDK) ──────────────────────
      // No hay regla aquí → clientes no pueden leer ni escribir _ratelimits
      match /_ratelimits/{uid} {
        allow read, write: if false;
      }
    }
  }
}
